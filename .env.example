# Aura Lily local deployment settings.
# Copy to .env before running docker compose, then edit values for your machine.

# Host-side ports. Container ports stay fixed at 8765 and 8787.
AURA_LILY_HTTP_PORT=8765
AURA_LILY_WS_PORT=8787

# Docker installs hermes-agent from PyPI by default. Pin here if you need a
# different version.
HERMES_AGENT_VERSION=0.15.2

# Hermes is installed inside the Linux container image. Your macOS hermes
# executable cannot be bind-mounted directly into a Linux container.
HERMES_COMMAND=hermes
HERMES_HOME=/home/aura/.hermes
# Kimi Coding Plan（kimi-for-coding，Anthropic 协议）的 key，hermes 只读环境变量。
KIMI_API_KEY=
AURA_COMPANION_HOME=/data/aura-companion
AURA_PERSONA_HOME=/data/aura-persona
AURA_PERSONA_ENABLED=0
# Protects Lily admin HTTP APIs. These are not provider/model API keys.
AURA_LILY_ADMIN_USER=admin
AURA_LILY_ADMIN_PASSWORD=
# Backward-compatible legacy token; prefer username/password for new installs.
AURA_LILY_ADMIN_TOKEN=
AURA_PERSONA_ADMIN_TOKEN=
AURA_LILY_HERMES_CONFIG_PATH=/data/aura-persona/config/hermes_runtime.json
AURA_LILY_AURA_RUNTIME_CONFIG_PATH=/data/aura-persona/config/aura_runtime.json
AURA_LILY_HOME_CITY=
AURA_USER_HOME_CITY=
AURA_USER_TIMEZONE=
AURA_USER_LATITUDE=
AURA_USER_LONGITUDE=
# device_ip means Lily only geolocates the ESP32-reported public IP. It never
# falls back to Docker/container public egress.
AURA_USER_LOCATION_MODE=device_ip
AURA_USER_GEO_PROVIDER=ipapi
AURA_USER_GEO_TIMEOUT_SECONDS=2.5
AURA_MODEL_MODE=hermes_main
AURA_MODEL_PROVIDER=
AURA_MODEL_MODEL=
AURA_MODEL_BASE_URL=
AURA_MODEL_API_KEY=
AURA_MODEL_TIMEOUT_SECONDS=90
AURA_MODEL_MAX_TOKENS=96
AURA_MODEL_TEMPERATURE=0.4
AURA_MODEL_REASONING_EFFORT=none
# Reuse Aura direct LLM HTTP connections between turns. This mainly helps
# second-and-later voice turns by avoiding repeated TCP/TLS setup; stale
# connections are discarded and retried once.
AURA_DIRECT_LLM_HTTP_KEEPALIVE_ENABLED=1
AURA_DIRECT_LLM_HTTP_KEEPALIVE_RETRY_ONCE=1
AURA_DIRECT_LLM_HTTP_WARM_ENABLED=1
AURA_FAST_REPLY_ENABLED=1
AURA_FAST_REPLY_MODE=hermes_main
AURA_VOICE_TURN_ENABLED=1
AURA_ACK_AND_ENQUEUE_ENABLED=1
AURA_CACHED_WEATHER_ENABLED=1
AURA_CACHED_WEATHER_CITY=
AURA_CACHED_WEATHER_TEMPERATURE=
AURA_CACHED_WEATHER_CONDITION=
AURA_CACHED_WEATHER_ICON=0
AURA_CACHED_WEATHER_HUMIDITY=
AURA_CACHED_WEATHER_SOURCE=
AURA_CACHED_WEATHER_OBSERVED_AT=
AURA_CACHED_WEATHER_TTL_SECONDS=3600
AURA_WEATHER_PROVIDER=open_meteo
AURA_WEATHER_AUTO_REFRESH_ENABLED=1
AURA_WEATHER_REFRESH_INTERVAL_SECONDS=1800
AURA_WEATHER_REQUEST_TIMEOUT_SECONDS=8
AURA_WEATHER_LATITUDE=
AURA_WEATHER_LONGITUDE=
AURA_TTS_ENABLED=0
AURA_TTS_PROVIDER=none
AURA_TTS_MODEL=
AURA_TTS_VOICE=
AURA_TTS_BASE_URL=
AURA_TTS_API_KEY=
AURA_TTS_FORMAT=pcm
AURA_TTS_SAMPLE_RATE=24000
AURA_TTS_TIMEOUT_SECONDS=15
# StepFun Step Plan TTS example. The gateway uses WebSocket streaming first and
# can fall back to /step_plan/v1/audio/speech.
# AURA_TTS_ENABLED=1
# AURA_TTS_PROVIDER=stepfun
# AURA_TTS_MODEL=stepaudio-2.5-tts
# AURA_TTS_VOICE=
# AURA_TTS_BASE_URL=https://api.stepfun.com/step_plan/v1
# AURA_TTS_API_KEY=
# Voice latency tuning. Keep the preface off by default so latency metrics and
# playback reflect the real assistant reply, not a filler cue.
AURA_TTS_WS_CHUNK_BYTES=2048
AURA_TTS_TEXT_CHUNK_CHARS=18
AURA_TTS_FIRST_CHUNK_CHARS=8
AURA_TTS_FIRST_CHUNK_MIN_CHARS=5
AURA_TTS_PREFETCH_CONCURRENCY=2
AURA_TTS_STEPFUN_WS_ENABLED=1
AURA_TTS_STEPFUN_WS_FALLBACK_HTTP=1
AURA_TTS_STEPFUN_WS_WARM_ENABLED=1
AURA_TTS_STEPFUN_WS_SAMPLE_RATE=16000
AURA_TTS_STEPFUN_WS_OPEN_TIMEOUT_SECONDS=2
AURA_TTS_STEPFUN_WS_MAX_SESSIONS=2
AURA_TTS_STEPFUN_WS_ACQUIRE_TIMEOUT_SECONDS=0.8
AURA_TTS_STEPFUN_WS_WARM_ACQUIRE_TIMEOUT_SECONDS=0.05
AURA_TTS_STEPFUN_WS_429_COOLDOWN_SECONDS=20
AURA_TTS_STEPFUN_WS_WAIT_FIRST_AUDIO=0
AURA_TTS_STEPFUN_WS_FIRST_AUDIO_WAIT_MS=1200
AURA_TTS_STEPFUN_WS_FIRST_SEGMENT_READY_WAIT_MS=300
# auto: first local short segment uses HTTP only if the warm WS session is not
# ready quickly; always: force first local segment over HTTP; off: pure WS.
AURA_TTS_STEPFUN_WS_FIRST_SEGMENT_HTTP_POLICY=auto
AURA_TTS_STEPFUN_WS_FLUSH_AFTER_DELTA=1
AURA_TTS_STEPFUN_WS_FLUSH_EACH_DELTA=0
AURA_TTS_PREFACE_ENABLED=0
AURA_TTS_PREFACE_DELAY_MS=700
AURA_TTS_PREFACE_MAX_WAIT_MS=200
AURA_TTS_PREFACE_MIN_DEVICE_BYTES=8192
AURA_TTS_PREFACE_TEXT=嗯。
AURA_TTS_AUDIO_SEND_PACING_ENABLED=1
AURA_TTS_AUDIO_SEND_PACING_RATE=1.6
AURA_TTS_AUDIO_SEND_PACING_PREFILL_MS=120
AURA_TTS_AUDIO_SEND_PACING_MAX_SLEEP_MS=25
AURA_TTS_AUDIO_SEND_DIRECT_PACKETS=5
AURA_BRIDGE_STREAM_ENABLED=1
AURA_BRIDGE_STREAM_MIN_CHARS=4
# First real reply segment sent from LLM streaming to TTS. Lower improves first
# audio latency; keep >=4 to avoid feeding unusably tiny fragments.
AURA_BRIDGE_STREAM_FIRST_SEGMENT_CHARS=6
# When StepFun WebSocket TTS is active, follow-up segments can be shorter
# because the TTS session stays open and buffers text internally.
AURA_BRIDGE_STREAM_WS_TTS_CHUNK_CHARS=8
# Very short local persona prefixes like "我在。" are kept in text but deferred
# until the first model phrase, avoiding slow tiny standalone TTS requests.
AURA_BRIDGE_STREAM_DEFER_LOCAL_PREFACE_CHARS=4
# Speculative bridge pre-start uses stable streaming-ASR partial text to warm
# Aura/Lily before final ASR. It buffers only: ESP32 hears audio after final ASR
# passes a strict exact/prefix reuse gate.
AURA_BRIDGE_SPECULATIVE_ENABLED=1
AURA_BRIDGE_SPECULATIVE_REUSE_ENABLED=1
AURA_BRIDGE_SPECULATIVE_MIN_CHARS=10
AURA_BRIDGE_SPECULATIVE_MIN_AUDIO_MS=700
AURA_BRIDGE_SPECULATIVE_MAX_EVENTS=12
AURA_BRIDGE_SPECULATIVE_MAX_CHARS=160
AURA_BRIDGE_SPECULATIVE_MIN_PREFIX_RATIO=0.9
AURA_SERVER_VAD_ENABLED=1
AURA_SERVER_VAD_SPEECH_RMS=280
AURA_SERVER_VAD_SILENCE_RMS=180
AURA_SERVER_VAD_MIN_SPEECH_MS=240
AURA_SERVER_VAD_SILENCE_MS=900
AURA_REALTIME_LOCAL_VAD_SILENCE_MS=600
AURA_STREAMING_ASR_LOCAL_VAD_SILENCE_MS=360
AURA_SERVER_VAD_MIN_AUDIO_MS=700
AURA_ASR_ENABLED=1
AURA_ASR_MODE=local
AURA_ASR_PROVIDER=local
AURA_ASR_MODEL=whisper-large-v3
AURA_ASR_BASE_URL=
AURA_ASR_API_KEY=
AURA_ASR_LANGUAGE=zh
AURA_ASR_TIMEOUT_SECONDS=30
# StepFun Step Plan Realtime experiment. This is Plan-covered and very fast, but
# it is a direct voice-to-voice route that bypasses Aura/Lily semantic handling.
# It is disabled by default unless AURA_STEPFUN_REALTIME_DIRECT_REPLY_ENABLED=1.
# AURA_ASR_MODE=api
# AURA_ASR_PROVIDER=stepfun-realtime
# AURA_ASR_MODEL=stepaudio-2.5-realtime
# AURA_ASR_BASE_URL=https://api.stepfun.com/step_plan/v1
# StepFun Step Plan ASR. This is the default Plan-covered production route:
# POST /step_plan/v1/audio/asr/sse with stepaudio-2.5-asr. It waits until the
# recording is submitted, then feeds Aura/Lily LLM and StepFun streaming TTS.
# AURA_ASR_MODE=api
# AURA_ASR_PROVIDER=stepfun
# AURA_ASR_MODEL=stepaudio-2.5-asr
# AURA_ASR_BASE_URL=https://api.stepfun.com/step_plan/v1
# AURA_ASR_API_KEY=
# StepFun semantic streaming ASR. This uses the /v1 realtime ASR route for
# transcription only; replies still go through Aura/Lily and streaming TTS.
# It is the fastest non-direct path, but confirm billing/permissions first.
# AURA_ASR_MODE=api
# AURA_ASR_PROVIDER=stepfun
# AURA_ASR_MODEL=stepaudio-2.5-asr-stream
# AURA_ASR_BASE_URL=https://api.stepfun.com/v1
AURA_ASR_STEPFUN_WS_ENABLED=1
AURA_ASR_STEPFUN_WS_SERVER_VAD=1
AURA_ASR_STEPFUN_WS_SILENCE_MS=360
AURA_ASR_STEPFUN_WS_THRESHOLD=0.5
AURA_ASR_STEPFUN_WS_FINAL_WAIT_MS=1200
AURA_ASR_STEPFUN_WS_COMMIT_WAIT_MS=1200
AURA_ASR_STEPFUN_WS_FINISH_QUEUE_TIMEOUT_MS=1000
AURA_ASR_STEPFUN_WS_QUEUE_FRAMES=96
AURA_ASR_STEPFUN_WS_STOP_SILENCE_MS=260
AURA_ASR_STEPFUN_WS_EARLY_TURN_ENABLED=0
AURA_ASR_STEPFUN_WS_EARLY_TURN_ALLOW_PARTIAL=0
# Keep this off for normal device use: partial ASR is useful for prefetch,
# but the final Aura reply should be based on confirmed/full ASR.
AURA_ASR_STEPFUN_WS_USE_PARTIAL_AS_FINAL=0
AURA_ASR_STEPFUN_WS_EARLY_TURN_MIN_CHARS=4
AURA_ASR_STEPFUN_WS_EARLY_TURN_MIN_AUDIO_MS=700
AURA_STREAMING_ASR_PREFETCH_ENABLED=1
AURA_STREAMING_ASR_PREFETCH_MIN_CHARS=5
AURA_STREAMING_ASR_PREFETCH_WAIT_MS=150
AURA_STREAMING_ASR_DETERMINISTIC_PARTIAL_TURN_ENABLED=0
AURA_STREAMING_ASR_DETERMINISTIC_PARTIAL_MIN_CHARS=7
AURA_STREAMING_ASR_DETERMINISTIC_PARTIAL_MIN_AUDIO_MS=900
# Streaming ASR partials should prefetch/speculate only by default. Keep early
# turn disabled unless you are explicitly testing speed over answer fidelity.
# If enabled, only these deterministic partial intents can start a reply before
# ASR final. Keep activity_or_location out if corrections regress.
AURA_STREAMING_ASR_DETERMINISTIC_PARTIAL_EARLY_INTENTS=weather,time,activity_or_location,local_quality
AURA_STREAMING_ASR_LOCAL_QUALITY_MIN_AUDIO_MS=900
# Stable partials can still feed bridge speculation. They should not become the
# user-visible answer before ASR final unless the early-turn flag is enabled.
AURA_STREAMING_ASR_STABLE_PARTIAL_TURN_ENABLED=1
AURA_STREAMING_ASR_STABLE_PARTIAL_EARLY_TURN_ENABLED=0
AURA_STREAMING_ASR_STABLE_PARTIAL_MIN_CHARS=6
AURA_STREAMING_ASR_STABLE_PARTIAL_MIN_AUDIO_MS=700
# Device voice-turn guardrails. These prevent a missing stop/final ASR event from
# leaving ESP32 stuck for minutes.
AURA_RECORDING_NO_AUDIO_TIMEOUT_SECONDS=2.5
AURA_RECORDING_MAX_SECONDS=8
AURA_ASR_LOW_CONFIDENCE_MAX_CHARS=2
AURA_GATEWAY_LOG_TRANSCRIPT_PREVIEW=1
# AURA_STEPFUN_REALTIME_DIRECT_REPLY_ENABLED=0
HERMES_PROVIDER=
HERMES_MODEL=
# Optional dropdown candidates for a Lily admin UI. API keys still live in Hermes.
# Format: provider:model|Label,provider:model|Label
HERMES_MODEL_OPTIONS=
HERMES_TIMEOUT=180
AURA_GATEWAY_BRIDGE_TIMEOUT_SECONDS=30
HERMES_TOOLSETS=web,terminal,file,code_execution,skills,memory
HERMES_SKILLS=
HERMES_MAX_CONCURRENCY=1
HERMES_QUEUE_TIMEOUT=30

# Host-side private runtime volumes. These directories are ignored by Git.
HERMES_HOME_HOST=./.docker/hermes-home
AURA_COMPANION_HOME_HOST=./.docker/aura-companion
AURA_PERSONA_HOME_HOST=./.docker/aura-persona

# Optional: install Hermes from a local source tree inside the build context
# instead of PyPI.
# Example: HERMES_AGENT_SOURCE=vendor/hermes-agent docker compose build
# HERMES_AGENT_SOURCE=
